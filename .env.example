# ===== Supabase =====
# מ-Project Settings > API בלוח הבקרה של Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# מפתח service role — סודי! בצד שרת בלבד, לעולם לא נחשף ללקוח
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== Resend (מיילים) =====
# מ-https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# כתובת השולח (חייבת להיות דומיין מאומת ב-Resend)
EMAIL_FROM="MyForm <noreply@yourdomain.com>"

# ===== App =====
# כתובת הבסיס הציבורית (לבניית לינקים ללקוח). בפיתוח: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# סוד לחתימת טוקנים (HMAC). צור מחרוזת אקראית ארוכה: openssl rand -hex 32
TOKEN_SIGNING_SECRET=change-me-to-a-long-random-string
